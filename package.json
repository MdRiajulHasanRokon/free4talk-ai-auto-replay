{
  "name": "free4talk-ai-auto-replay",
  "version": "3.1.0",
  "description": "An open-source AI auto-reply browser extension for Free4Talk with customizable prompts and support for Chromium-based browsers.",
  "main": "background.js",
  "scripts": {
    "build": "esbuild src/popup/index.jsx --bundle --outfile=popup.js --loader:.jsx=jsx && esbuild src/memory/index.jsx --bundle --outfile=memory.js --loader:.jsx=jsx"
  },
  "keywords": [
    "free4talk",
    "free4talk-extension",
    "free4talk-ai",
    "browser-extension",
    "chrome-extension",
    "ai-auto-reply",
    "chat-automation",
    "manifest-v3",
    "language-learning",
    "openai",
    "gemini-ai",
    "nvidia-nim",
    "groq",
    "openrouter"
  ],
  "author": "MdRiajulHasanRokon",
  "homepage": "https://github.com/MdRiajulHasanRokon/free4talk-ai-auto-replay",
  "bugs": {
    "url": "https://github.com/MdRiajulHasanRokon/free4talk-ai-auto-replay/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MdRiajulHasanRokon/free4talk-ai-auto-replay.git"
  },
  "license": "MIT",
  "dependencies": {
    "esbuild": "^0.28.1",
    "react": "^19.2.8",
    "react-dom": "^19.2.8"
  }
}
