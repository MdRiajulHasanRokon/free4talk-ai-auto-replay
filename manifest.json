{
  "manifest_version": 3,
  "name": "Free4Talk AI",
  "version": "3.1.0",
  "description": "Lightning-fast AI Free4Talk bot & auto replay chat assistant. Powered by NVIDIA NIM, ChatGPT, & Google Gemini with smart auto-switching and fallback.",
  "author": "Free4Talk AI",

  "permissions": [
    "storage",
    "alarms",
    "tabs"
  ],

  "host_permissions": [
    "*://www.free4talk.com/*",
    "*://free4talk.com/*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://openrouter.ai/*",
    "https://integrate.api.nvidia.com/*",
    "https://api.groq.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "*://www.free4talk.com/*",
        "*://free4talk.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["memory.html", "memory.css", "memory.js", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Free4Talk AI",
    "default_icon": {
      "16": "icons/icon16.png",
      "19": "icons/icon19.png",
      "32": "icons/icon32.png",
      "38": "icons/icon38.png",
      "48": "icons/icon48.png",
      "64": "icons/icon64.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "19": "icons/icon19.png",
    "32": "icons/icon32.png",
    "38": "icons/icon38.png",
    "48": "icons/icon48.png",
    "64": "icons/icon64.png",
    "128": "icons/icon128.png"
  }
}
